rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // İlanlar: Herkes ilanları arayıp görüntüleyebilir
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Kullanıcılar: Sadece kendileri ve işverenler görebilir
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    // Diğer koleksiyonlar (Kurabiye Satis vb.) için varsayılan kuralları koruyoruz
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
